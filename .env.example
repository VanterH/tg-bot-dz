# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================

# Telegram Bot Token - получить у @BotFather
# Пример: 1234567890:ABCdefGHIJKLMNopqRsTUVWxyz
BOT_TOKEN=your_bot_token_here

# Telegram ID администратора - получить у @userinfobot
# Пример: 123456789
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Telegram ID экспертов (через запятую)
# Пример: 123456789,987654321
EXPERT_TELEGRAM_IDS=expert_id_1,expert_id_2


# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL (рекомендуется для продакшена)
# Формат: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/doterra_bot

# Для SQLite (локальная разработка) - раскомментируйте и закомментируйте PostgreSQL
# DATABASE_URL=sqlite:///./doterra_bot.db


# ============================================
# YANDEXGPT API CONFIGURATION
# ============================================

# ID каталога в Yandex Cloud
# Получить в консоли Yandex Cloud: https://console.cloud.yandex.ru/
YANDEX_FOLDER_ID=your_folder_id_here

# API ключ для доступа к YandexGPT
# Создать в разделе "Сервисные аккаунты" с ролью ai.languageModels.user
YANDEX_API_KEY=your_api_key_here

# Модель YandexGPT
# Доступные: yandexgpt-lite, yandexgpt
YANDEX_MODEL=yandexgpt-lite


# ============================================
# RAG (RETRIEVAL-AUGMENTED GENERATION) SETTINGS
# ============================================

# Режим мок-тестирования (true/false)
# true - использовать шаблонные ответы, false - использовать реальный API
RAG_MOCK_MODE=false

# Количество релевантных чанков для поиска
RAG_TOP_K=5

# Порог уверенности для автоматического ответа (0.0 - 1.0)
RAG_CONFIDENCE_THRESHOLD=0.6


# ============================================
# ADMIN PANEL CONFIGURATION
# ============================================

# Секретный ключ для админ-панели
# Придумайте сложный пароль
SECRET_KEY=your_secret_key_here


# ============================================
# PAYMENT LINKS (ВНЕШНИЕ ССЫЛКИ ДЛЯ ОПЛАТЫ)
# ============================================

# Ссылки на оплату в рублях
PAYMENT_LINK_RUB_ONE_TIME=https://your-payment-system.com/one_time_rub
PAYMENT_LINK_RUB_WEEK=https://your-payment-system.com/week_rub
PAYMENT_LINK_RUB_MONTH=https://your-payment-system.com/month_rub

# Ссылки на оплату в долларах
PAYMENT_LINK_USD_ONE_TIME=https://your-payment-system.com/one_time_usd
PAYMENT_LINK_USD_WEEK=https://your-payment-system.com/week_usd
PAYMENT_LINK_USD_MONTH=https://your-payment-system.com/month_usd


# ============================================
# SYSTEM SETTINGS
# ============================================

# Часовой пояс
TIMEZONE=Europe/Moscow

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO